{
  "dashboard": {
    "uid": "964eb568-8fd7-4d4e-bdc9-6f491f247b46",
    "title": "Smart Traffic Monitoring",
    "tags": ["traffic", "azure", "ml"],
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 36,
    "panels": [
      {
        "id": 1,
        "title": "Vehicles Detected Over Time",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | summarize total_vehicles=sum(vehicles_d) by bin(TimeGenerated, 2m) | order by TimeGenerated asc",
            "resultFormat": "time_series"
          }
        }],
        "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
      },
      {
        "id": 2,
        "title": "Accident Alerts Over Time",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | where accident_b == \"True\" | summarize accidents=count() by bin(TimeGenerated, 2m) | order by TimeGenerated asc",
            "resultFormat": "time_series"
          }
        }],
        "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 20 } } }
      },
      {
        "id": 3,
        "title": "Total Vehicles Today",
        "type": "stat",
        "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | summarize total=sum(vehicles_d)",
            "resultFormat": "table"
          }
        }],
        "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value" }
      },
      {
        "id": 4,
        "title": "Total Accidents Today",
        "type": "stat",
        "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | where accident_b == \"True\" | count",
            "resultFormat": "table"
          }
        }],
        "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value", "colorMode": "background" }
      },
      {
        "id": 5,
        "title": "Avg Anomaly Score",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | summarize avg_score=avg(anomaly_score_d)",
            "resultFormat": "table"
          }
        }],
        "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.4 }, { "color": "red", "value": 0.7 }] } } }
      },
      {
        "id": 6,
        "title": "Frames Processed",
        "type": "stat",
        "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | summarize dcount(frame_d)",
            "resultFormat": "table"
          }
        }],
        "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "unit": "short" } },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value" }
      },
      {
        "id": 7,
        "title": "Vehicle Type Breakdown",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | where class_s in (\"car\",\"truck\",\"motorcycle\",\"bus\") | summarize count() by class_s",
            "resultFormat": "table"
          }
        }],
        "options": { "pieType": "pie", "displayLabels": ["name", "percent"] }
      },
      {
        "id": 8,
        "title": "Recent Detections",
        "type": "table",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
        "targets": [{
          "refId": "A",
          "queryType": "Azure Log Analytics",
          "datasource": { "type": "grafana-azure-monitor-datasource", "uid": "afkjnweadltz4a" },
          "azureLogAnalytics": {
            "query": "TrafficInference_CL | project TimeGenerated, frame=frame_d, vehicles=vehicles_d, class=class_s, confidence=confidence_d, anomaly_score=anomaly_score_d, accident=accident_b | order by TimeGenerated desc | take 50",
            "resultFormat": "table"
          }
        }]
      }
    ]
  },
  "overwrite": true
}
