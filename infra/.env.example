# Copy this to .env and fill in your values — never commit .env to git
LOCATION="eastus2"
RG="rg-traffic-prod"
PREFIX="trafficprod"
STORAGE_ACCOUNT="${PREFIX}dlake"
EVENTHUB_NS="${PREFIX}ehns"
AML_WORKSPACE="${PREFIX}aml"
ADB_WORKSPACE="${PREFIX}adb"
ADF_NAME="${PREFIX}adf"
AKS_NAME="${PREFIX}aks"
ACR_NAME="${PREFIX}acr"
KV_NAME="${PREFIX}kv"
AKS_NODE_COUNT=3
AKS_VM_SIZE="Standard_DS3_v2"
